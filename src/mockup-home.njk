---
permalink: /mockup-home/
eleventyExcludeFromCollections: true
---
<!doctype html>
<html lang="en" data-mode="research">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Homepage mockup · {{ site.name }}</title>
  <meta name="robots" content="noindex">
  <link rel="icon" type="image/svg+xml" href="/assets/img/logo/favicon.svg">
  <link rel="stylesheet" href="/assets/css/site.css?v={{ buildTime }}">
  <style>
    /* Mockup-only layout: full-viewport panels with the real header floating
       on top of the imagery (same markup, size, and padding as the live site;
       colors flipped to white over a top scrim). */
    html, body { height: 100dvh; }
    body { margin: 0; }

    body > .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 10;
      padding-bottom: 10px;
    }
    /* Frosted backdrop with a softly fading bottom edge: lives on a pseudo
       element that extends below the header and is masked to transparent. */
    body > .site-header::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      background: rgba(22, 26, 29, 0.45);
      -webkit-backdrop-filter: blur(10px);
      backdrop-filter: blur(10px);
      pointer-events: none;
    }
    /* No horizontal rule in this design */
    .site-header .rule { display: none; }

    /* Compact header (from the second panel on): logo left, menu/hamburger right */
    .site-header.mock-compact {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-start;
      gap: 12px 24px;
      padding: 8px var(--gutter);
    }
    .mock-compact .wordmark { flex-direction: row; padding: 0; margin: 0; }
    .mock-compact .wordmark__name { display: none; }
    .mock-compact .wordmark__logo { width: 44px; height: 44px; }
    .mock-compact .mode-toggle { display: none; }
    .mock-compact .site-header__utility { margin: 0 0 0 auto; }   /* hamburger to the right */
    .mock-compact .site-menu { margin: 0; max-width: none; padding: 0; justify-content: flex-end; }
    @media (max-width: 879px) {
      /* narrow: the opened menu drops to its own row, items aligned right */
      .mock-compact .site-menu { flex-basis: 100%; align-items: flex-end; }
    }

    /* Logo inverts against the panel behind it. Only the outer disc is
       recolored (svg > circle); the dot of the "i" sits inside the <g> and
       inherits the mark color. */
    .mock-on-light .wordmark__logo svg > circle { fill: var(--black); }
    .mock-on-light .wordmark__logo svg g { fill: var(--white); }
    .mock-on-dark .wordmark__logo svg > circle { fill: var(--white); }
    .mock-on-dark .wordmark__logo svg g { fill: var(--black); }
    .site-header .wordmark__name { color: var(--white); text-shadow: 0 1px 8px rgba(0,0,0,0.5); }
    .site-header .wordmark__suffix--lab { color: var(--white); }
    .site-header .site-menu__link { color: var(--white); text-shadow: 0 1px 8px rgba(0,0,0,0.5); }
    .site-header .site-menu__link:hover,
    .site-header .site-menu__link.is-active { color: #A9C4E8; }
    .site-header .mode-toggle { border-color: var(--white); background: transparent; }
    .site-header .mode-toggle__btn { color: var(--white); }
    .site-header .mode-toggle__btn[aria-selected="true"] { background: var(--white); color: var(--black); }
    .site-header .menu-btn__bar { background: var(--white); }

    .mock-deck {
      height: 100dvh;
      overflow-y: auto;
      scroll-snap-type: y mandatory;
      scrollbar-width: none;
    }
    .mock-deck::-webkit-scrollbar { display: none; }
    .panel {
      position: relative;
      height: 100%;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      background-size: cover;
      background-position: center;
      display: flex;
      align-items: flex-end;
    }
    .panel::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(22,26,29,0.78) 0%, rgba(22,26,29,0.25) 38%, rgba(22,26,29,0.05) 60%);
      pointer-events: none;
    }
    .panel__text {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--gutter) 44px;
      color: var(--white);
    }
    .panel__count {
      font-size: 12px;
      letter-spacing: 0.14em;
      opacity: 0.75;
      margin: 0 0 8px;
      font-variant-numeric: tabular-nums;
    }
    .panel__title {
      font-size: clamp(20px, 2.4vw, 30px);
      line-height: 1.06;
      font-weight: 700;
      letter-spacing: -0.015em;
      margin: 0 0 10px;
      max-width: 18em;
      text-shadow: 0 2px 14px rgba(0,0,0,0.45);
    }
    .panel__subtitle {
      font-family: Georgia, "Times New Roman", Times, serif;
      font-style: italic;
      font-size: clamp(14px, 1.4vw, 18px);
      line-height: 1.45;
      opacity: 0.9;
      margin: 0 0 18px;
      max-width: 36em;
      text-shadow: 0 1px 8px rgba(0,0,0,0.5);
    }
    .panel__link {
      display: inline-block;
      color: var(--white);
      text-decoration: none;
      font-size: 14px;
      font-weight: 700;
      padding: 9px 16px;
      border: 1px solid rgba(255,255,255,0.65);
      border-radius: 5px;
      backdrop-filter: blur(2px);
      transition: background 0.15s ease, color 0.15s ease;
    }
    .panel__link:hover { background: var(--white); color: var(--black); text-decoration: none; }

    /* First panel: the tagline centers in the space above the project caption */
    .panel--first {
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-end;
    }
    .panel--first::after {
      background: linear-gradient(to top, rgba(22,26,29,0.78) 0%, rgba(22,26,29,0.4) 38%, rgba(22,26,29,0.32) 100%);
    }
    .panel__tagline {
      position: relative;
      flex: 1;
      min-height: 0;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      /* top padding keeps the centered text clear of the overlaid header (~280px tall) */
      padding: 300px var(--gutter) 0;
      pointer-events: none;
    }
    .panel__tagline p {
      font-family: Georgia, "Times New Roman", Times, serif;
      font-style: italic;
      font-size: clamp(20px, 2.4vw, 30px);
      line-height: 1.55;
      color: var(--white);
      max-width: 26em;
      margin: 0;
      text-shadow: 0 2px 12px rgba(0,0,0,0.55);
    }
    .scroll-hint {
      position: absolute;
      left: 50%;
      bottom: 18px;
      transform: translateX(-50%);
      z-index: 1;
      color: var(--white);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      opacity: 0.8;
      animation: hintFloat 2.2s ease-in-out infinite;
    }
    @keyframes hintFloat {
      0%, 100% { transform: translate(-50%, 0); }
      50% { transform: translate(-50%, 6px); }
    }

    .mock-badge {
      position: fixed;
      right: 16px;
      bottom: 16px;
      z-index: 20;
      background: var(--blue);
      color: var(--white);
      font-size: 12px;
      font-weight: 700;
      padding: 8px 12px;
      border-radius: 5px;
      opacity: 0.92;
    }
    .mock-badge a { color: var(--white); }
  </style>
</head>
<body>
  {# The real site header, verbatim from base.njk: logo, wordmark, toggle, menu, rule #}
  <header class="site-header">
    <a class="wordmark" href="/">
      <span class="wordmark__logo">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 283.5 283.5" role="img" aria-label="AIM Lab logo">
          <circle cx="141.7" cy="141.7" r="138.2" fill="var(--logo-bg)"/>
          <g fill="var(--logo-mark)">
            <polygon points="95.7 152.1 86.9 152.1 78.2 175.8 95.7 175.8 95.7 152.1"/>
            <polygon points="137.1 110.6 137.1 192.1 152.2 233.6 181.9 233.6 137.1 110.6"/>
            <rect x="101.6" y="94.3" width="29.6" height="139.2"/>
            <polygon points="262.2 94.3 211.5 233.6 181.9 233.6 232.6 94.3 262.2 94.3"/>
            <polygon points="232.6 193.1 232.6 233.6 262.2 233.6 262.2 111.7 232.6 193.1"/>
            <circle cx="116.4" cy="64.7" r="14.8"/>
            <polyline points="50.9 233.6 95.7 110.6 50.9 233.6 21.3 233.6 71.9 94.3 95.7 94.3 95.7 110.6"/>
          </g>
        </svg>
      </span>
      <span class="wordmark__name">{{ site.fullName }}<span class="wordmark__suffix wordmark__suffix--lab"> Laboratory</span><span class="wordmark__suffix wordmark__suffix--studio"> Studio</span></span>
    </a>
    <div class="site-header__utility">
      <div class="mode-toggle" role="tablist" aria-label="View mode">
        <button class="mode-toggle__btn" data-mode="research" role="tab" aria-selected="true">Science</button>
        <button class="mode-toggle__btn" data-mode="gallery"  role="tab" aria-selected="false">Art</button>
      </div>
      <button class="menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="site-menu">
        <span class="menu-btn__bar"></span>
        <span class="menu-btn__bar"></span>
        <span class="menu-btn__bar"></span>
      </button>
    </div>
    <nav class="site-menu site-menu--research" id="site-menu" aria-label="Main" hidden>
      {% for item in site.nav %}
        <a href="{{ item.href }}" class="site-menu__link">{{ item.label }}</a>
      {% endfor %}
    </nav>
    <nav class="site-menu site-menu--gallery" id="site-menu-art" aria-label="Main (Art)" hidden>
      {% for item in site.navArt %}
        <a href="{{ item.href }}" class="site-menu__link">{{ item.label }}</a>
      {% endfor %}
    </nav>
    <div class="rule" role="presentation"></div>
  </header>

  <main class="mock-deck">
    {% for p in collections.projects %}
    <section class="panel{% if loop.first %} panel--first{% endif %}" style="background-image: url('{{ p.data.hero | heroLargeSrc }}')">
      {% if loop.first %}
      <div class="panel__tagline">
        <p>We explore intelligent matter at the intersection of mechanics, materials, and geometry. We pursue this goal both scientifically and through the practice of art. We believe such work is only possible through our commitment to building an equal, diverse and inclusive environment.</p>
      </div>
      {% endif %}
      <div class="panel__text">
        <p class="panel__count">{% if loop.index < 10 %}0{% endif %}{{ loop.index }} / {{ loop.length }}</p>
        <h2 class="panel__title">{{ p.data.title }}</h2>
        {% if p.data.subtitle %}<p class="panel__subtitle">{{ p.data.subtitle }}</p>{% endif %}
        <a class="panel__link" href="{{ p.url }}">View project</a>
      </div>
      {% if loop.first %}<div class="scroll-hint">Scroll</div>{% endif %}
    </section>
    {% endfor %}
  </main>

  <div class="mock-badge">Mockup · <a href="/">real homepage</a></div>
  <script src="/assets/js/mode.js?v={{ buildTime }}" defer></script>
  <script>
    // Header state machine: compact from the second panel on, and logo colors
    // chosen from the brightness of the image band behind the header.
    (function () {
      var deck = document.querySelector(".mock-deck");
      var header = document.querySelector(".site-header");
      var panels = Array.prototype.slice.call(deck.querySelectorAll(".panel"));

      // Estimate each panel's brightness from the top band of its hero image.
      panels.forEach(function (panel) {
        var m = (panel.getAttribute("style") || "").match(/url\('([^']+)'\)/);
        if (!m) { panel.dataset.bg = "dark"; return; }
        var img = new Image();
        img.onload = function () {
          try {
            var c = document.createElement("canvas");
            c.width = 32; c.height = 8;
            var ctx = c.getContext("2d");
            ctx.drawImage(img, 0, 0, img.naturalWidth, img.naturalHeight / 4, 0, 0, 32, 8);
            var d = ctx.getImageData(0, 0, 32, 8).data;
            var sum = 0;
            for (var i = 0; i < d.length; i += 4) {
              sum += 0.2126 * d[i] + 0.7152 * d[i + 1] + 0.0722 * d[i + 2];
            }
            panel.dataset.bg = (sum / (d.length / 4)) > 128 ? "light" : "dark";
          } catch (e) {
            panel.dataset.bg = "dark";
          }
          update();
        };
        img.onerror = function () { panel.dataset.bg = "dark"; update(); };
        img.src = m[1];
      });

      function update() {
        var i = Math.round(deck.scrollTop / deck.clientHeight);
        i = Math.max(0, Math.min(panels.length - 1, i));
        header.classList.toggle("mock-compact", i > 0);
        var bg = panels[i].dataset.bg || "dark";
        header.classList.toggle("mock-on-light", bg === "light");
        header.classList.toggle("mock-on-dark", bg === "dark");
      }
      deck.addEventListener("scroll", update, { passive: true });
      update();
    })();
  </script>
</body>
</html>
