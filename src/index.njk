---
layout: layouts/base.njk
---
{# SCIENCE MODE — banded layout #}
<section class="mode-pane mode-pane--research" data-pane="research">
  <p class="home-tagline">We explore intelligent matter at the intersection of mechanics, materials, and geometry. We pursue this goal both scientifically and through the practice of art. We believe such work is only possible through our commitment to building an equal, diverse and inclusive environment.</p>
  <div class="rule" role="presentation"></div>
  <div class="home">
    <section class="band">
      <div class="band__head">
        <div class="eyebrow">Recent research highlights</div>
        <a class="band__all" href="/research/">All research</a>
      </div>
      {# Cards are rendered twice; JS wraps the scroll position so the strip loops
         forever. The second copy is hidden from screen readers and tab order. #}
      <div class="research-scroller" data-infinite tabindex="0" aria-label="Research projects, scroll sideways to browse">
        {% for copy in [0, 1] %}
          {% for p in collections.projects %}
            <a class="research-card" href="{{ p.url }}"{% if copy == 1 %} aria-hidden="true" tabindex="-1"{% endif %}>
              <div class="research-card__img">
                {% if p.data.hero %}<img src="{{ p.data.hero | heroSrc }}" alt="{{ p.data.title }}" loading="lazy">{% endif %}
              </div>
              <div class="research-card__title">{{ p.data.title }}</div>
              {% if p.data.subtitle %}<div class="research-card__subtitle">{{ p.data.subtitle }}</div>{% endif %}
            </a>
          {% endfor %}
        {% endfor %}
      </div>
    </section>

    <section class="band">
      <div class="band__head">
        <div class="eyebrow">Join our group</div>
      </div>
      <p class="join-nudge">We are recruiting PhD students and postdocs across fabrication, simulation, and programmable materials. <a href="/join-us/">See open positions</a></p>
    </section>
  </div>
</section>

{# ART MODE — gallery only #}
<section class="mode-pane mode-pane--gallery container page" data-pane="gallery">
  <h1 class="page__title">Studio</h1>
  <p class="page__lede">The studio is where we make our ideas physical: objects, textiles, and structures that explore the same intelligent matter through the practice of art.</p>
  <div class="filter-bar" data-filter-bar="art" role="group" aria-label="Filter by theme">
    <button class="filter-btn is-active" data-filter="all">All</button>
    {% for t in site.artThemes %}
      <button class="filter-btn" data-filter="{{ t }}">{{ t }}</button>
    {% endfor %}
  </div>

  <div class="art-grid" data-filter-grid="art">
    {% for p in collections.art %}
      <a class="art-card" href="{{ p.url }}" data-tags="{{ p.data.tags | join('|') }}">
        <div class="art-card__img">
          {% if p.data.hero %}<img src="{{ p.data.hero | heroSrc }}" alt="{{ p.data.title }}" loading="lazy">{% endif %}
        </div>
        <div class="art-card__title">{{ p.data.title }}</div>
        {% if p.data.subtitle %}<div class="art-card__subtitle">{{ p.data.subtitle }}</div>{% endif %}
      </a>
    {% endfor %}
  </div>
</section>
