---
layout: layouts/base.njk
forceMode: research
title: Publications
---
{#
  This page is generated from the files in src/publications/ (one per paper).
  To add a paper, copy src/publications/_TEMPLATE.md. Do not hand-edit the list
  below; it is built automatically and grouped by year in .eleventy.js.
#}
<section class="container page">
  <h1 class="page__title">Publications</h1>
  <p class="page__lede">Journal articles, conference papers, theses, and patents. The current list is also on <a href="https://scholar.google.com/citations?user=4KWxfHAAAAAJ&hl=en" class="ext">Google Scholar</a>.</p>

  {% if covers.length %}
  <div class="cover-grid" data-gallery="covers">
    {% for cover in covers %}
    <figure class="cover-item" data-gallery-item data-src="/assets/img/covers/{{ cover.src }}" data-caption="{{ cover.caption | default('') }}">
      <img src="/assets/img/covers/{{ cover.src }}" alt="{{ cover.caption or 'Journal cover' }}" loading="lazy">
      {% if cover.caption %}<figcaption>{{ cover.caption }}</figcaption>{% endif %}
    </figure>
    {% endfor %}
  </div>

  <div class="lightbox" data-lightbox="covers" aria-hidden="true">
    <button class="lightbox__close" data-lightbox-close aria-label="Close">×</button>
    <button class="lightbox__nav lightbox__nav--prev" data-lightbox-prev aria-label="Previous">‹</button>
    <img class="lightbox__img" data-lightbox-img src="" alt="">
    <button class="lightbox__nav lightbox__nav--next" data-lightbox-next aria-label="Next">›</button>
    <div class="lightbox__caption" data-lightbox-caption></div>
  </div>
  {% endif %}

  {% for group in collections.pubsByYear %}
  <div class="pub-year">
    <h2 class="pub-year__heading">{{ group.year }}</h2>
    <ol class="pub-list">
      {% for p in group.items %}
      <li class="pub">
        <span class="pub__authors">{{ p.data.authors }}</span>
        <span class="pub__title">{% if p.data.doi %}<a href="https://doi.org/{{ p.data.doi }}" target="_blank" rel="noopener">{{ p.data.title }}</a>.{% elif p.data.url %}<a href="{{ p.data.url }}" target="_blank" rel="noopener">{{ p.data.title }}</a>.{% else %}{{ p.data.title }}.{% endif %}</span>
        <span class="pub__venue">{{ p.data.venue | safe }}{% if p.data.note %} <span class="pub__note">{{ p.data.note }}</span>{% endif %}</span>
        {% if p.data.pdf %}<span class="pub__links"><a href="{{ p.data.pdf }}" target="_blank" rel="noopener">PDF</a></span>{% endif %}
      </li>
      {% endfor %}
    </ol>
  </div>
  {% endfor %}
</section>
