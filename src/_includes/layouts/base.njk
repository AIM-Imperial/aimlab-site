                <polygon points="137.1 110.6 137.1 192.1 152.2 233.6 181.9 233.6 137.1 110.6"/>
                <rect x="101.6" y="94.3" width="29.6" height="139.2"/>
                <polygon points="262.2 94.3 211.5 233.6 181.9 233.6 232.6 94.3 262.2 94.3"/>
                <polygon points="232.6 193.1 232.6 233.6 262.2 233.6 262.2 111.7 232.6 193.1"/>
                <circle cx="116.4" cy="64.7" r="14.8"/>
                <polyline points="50.9 233.6 95.7 110.6 50.9 233.6 21.3 233.6 71.9 94.3 95.7 94.3 95.7 110.6" fill="var(--logo-mark)"/>
              </g>
            </svg>
          </span>
        </div>

        <nav class="site-footer__col site-footer__nav--research" aria-label="Footer">
          <a href="/">Home</a>
          {% for item in site.nav %}{% if item.href != "/join/" %}<a href="{{ item.href }}">{{ item.label }}</a>{% endif %}{% endfor %}
        </nav>

        <div class="site-footer__col site-footer__nav--research">
          <a href="/join/">Join</a>
          <a href="/contact/">Contact &amp; find us</a>
        </div>

        <nav class="site-footer__col site-footer__nav--gallery" aria-label="Footer">
          {% for item in site.navArt %}<a href="{{ item.href }}">{{ item.label }}</a>{% endfor %}
