<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ project.data.title }} · printable sheet</title>
  <meta name="robots" content="noindex">
  <link rel="icon" type="image/svg+xml" href="/assets/img/logo/favicon.svg">
  <link rel="stylesheet" href="/assets/css/print.css?v={{ buildTime }}">
</head>
<body class="printpage">
  <div class="printbar" role="toolbar" aria-label="Print controls">
    <button type="button" onclick="window.print()">Print / Save as PDF</button>
    <a href="/projects/{{ project.fileSlug }}/">Back to project</a>
  </div>
  {{ content | safe }}
</body>
</html>
